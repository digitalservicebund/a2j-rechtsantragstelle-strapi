{
  "name": "a-2-j-strapi",
  "version": "0.1.0",
  "private": true,
  "description": "A Strapi application",
  "license": "MIT",
  "scripts": {
    "build": "npm run plugin:build && strapi build",
    "develop": "strapi develop",
    "start": "strapi start",
    "strapi": "strapi",
    "test": "NODE_ENV=test jest --forceExit --detectOpenHandles",
    "transfer": "strapi transfer --from https://a2j-strapi.staging.tech.digitalservice.dev/admin",
    "plugin:build": "npm run build --workspace strapi-plugin-gh-workflow-trigger-v5",
    "plugin:develop": "npm run watch --workspace plugins/strapi-plugin-gh-workflow-trigger-v5"
  },
  "jest": {
    "noStackTrace": true,
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".tmp",
      ".cache",
      "/plugins/"
    ],
    "testTimeout": 70000
  },
  "dependencies": {
    "@strapi/plugin-users-permissions": "5.47.1",
    "@strapi/provider-upload-aws-s3": "5.47.1",
    "@strapi/strapi": "5.47.1",
    "pg": "^8.20.0",
    "pluralize": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "strapi-plugin-gh-workflow-trigger-v5": "file:plugins/strapi-plugin-gh-workflow-trigger-v5",
    "strapi-v5-plugin-populate-deep": "4.3.2",
    "lodash": "^4.18.1",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "better-sqlite3": "^12.11.1",
    "jest": "^30.4.1",
    "supertest": "^7.2.2",
    "@strapi/sdk-plugin": "^6.1.1"
  },
  "engines": {
    "node": "^24.15.0",
    "npm": "^11.6.0"
  },
  "workspaces": [
    "plugins/strapi-plugin-gh-workflow-trigger-v5"
  ],
  "overrides": {
    "esbuild": "0.25.0",
    "ajv": "8.18.0",
    "lodash": "^4.18.1"
  },
  "strapi": {
    "uuid": "75be5f21-db3a-4a6f-9069-20b0c6b8e10c",
    "telemetryDisabled": true
  }
}
